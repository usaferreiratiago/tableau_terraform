aws_region   = "us-east-1"
project_name = "tableau-server"

# Networking - leave vpc_id/subnet_id null to use the default VPC/subnet
vpc_id    = null
subnet_id = null

allowed_ssh_cidrs = ["203.0.113.4/32"]  # restrict to your own IP
allowed_web_cidrs = ["203.0.113.0/24"]  # restrict to your office/VPN CIDR

# Compute
instance_type        = "m5.xlarge"
root_volume_size_gb  = 150
key_pair_name        = null # set to an existing key pair name, or leave null to auto-generate

# Tableau Server installer
# Get the current direct-download URL for your desired version from:
# https://www.tableau.com/support/releases/server
tableau_installer_url = "https://downloads.tableau.com/esdalt/2024.2.3/tableau-server-2024-2-3_amd64.deb"

tableau_license_key    = "XXXX-XXXX-XXXX-XXXX-XXXX"
tableau_admin_username = "tsadmin"
tableau_admin_password = "ReplaceWithAStrongPassword!"

tableau_registration = {
  first_name = "Jane"
  last_name  = "Doe"
  email      = "jane.doe@example.com"
  company    = "Example Corp"
  title      = "Data Engineer"
  department = "Analytics"
  industry   = "Technology"
  phone      = "555-555-5555"
  city       = "Austin"
  state      = "TX"
  zip        = "78701"
  country    = "United States"
}

tags = {
  Project     = "tableau-server"
  Environment = "prod"
  ManagedBy   = "terraform"
}
