# terraform.tfvars.example - Example configuration

project_name   = "tableau"
environment    = "dev"
aws_region     = "us-east-1"

vpc_cidr               = "10.0.0.0/16"
public_subnet_cidrs    = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs   = ["10.0.10.0/24", "10.0.11.0/24"]
data_subnet_cidrs      = ["10.0.20.0/24", "10.0.21.0/24"]

tableau_node_count      = 1
tableau_instance_type   = "t3.xlarge"
bastion_instance_type   = "t3.micro"
tableau_data_volume_size = 500

enable_bastion = true

# For HTTPS, provide your ACM certificate ARN (must be in us-east-1)
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/your-cert-id"

# Replace with your SSH public key
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ..."

tags = {
  Project     = "Tableau"
  ManagedBy   = "Terraform"
  Environment = "dev"
}

# ============================================
# SENSITIVE VARIABLES - SET VIA ENVIRONMENT!
# ============================================
# DO NOT put real values here! Use:
# export TF_VAR_tableau_license_key="YOUR-KEY"
# export TF_VAR_tableau_admin_password="YourPassword"
# export TF_VAR_repository_password="DBPassword"
# ============================================