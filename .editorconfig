# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Standard indentation for all text files
indent_style = space
indent_size = 2

# Terraform/HCL specific
[*.{tf,tfvars,hcl}]
indent_style = space
indent_size = 2

# JSON and YAML (for your workflows and policies)
[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2